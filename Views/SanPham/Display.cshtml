@model DoAnCoSo.Models.SanPham

@{
    ViewData["Title"] = "Product Details";
}

@section Styles {
    <style>
        .star-rating {
            color: #ffd700;
            font-size: 1.2rem;
        }
        .review-date {
            color: #6c757d;
            font-size: 0.9rem;
        }
        .review-card {
            border-left: 4px solid #007bff;
            margin-bottom: 1rem;
            padding: 1rem;
            background-color: #f8f9fa;
        }
        .rating-group {
            display: inline-flex;
            flex-direction: row-reverse;
            position: relative;
        }
        .rating-input {
            display: none;
        }
        .rating-label {
            cursor: pointer;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #ddd;
            transition: all 0.2s ease;
        }
        .rating-label:hover,
        .rating-label:hover ~ .rating-label {
            color: #ffd700;
        }
        .rating-input:checked ~ .rating-label {
            color: #ffd700;
        }
        .rating-group:not(:hover) .rating-input:checked ~ .rating-label {
            color: #ffd700;
        }
        .rating-description {
            margin-top: 0.5rem;
            font-size: 0.9rem;
            color: #6c757d;
        }
    </style>
}

<div class="container mb-5">
    <!-- Breadcrumb navigation -->
    <nav aria-label="breadcrumb" class="mt-3 mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "SanPham")">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenSanPham</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product images column -->
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="main-image-container position-relative" style="height: 450px; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Url.Content(Model.ImageUrl)" alt="@Model.TenSanPham" class="main-image w-100 h-100" style="object-fit: cover; transition: all 0.5s ease;" />
                    }
                    else
                    {
                        <img src="@Url.Content("~/images/default-product.jpg")" alt="Default Image" class="main-image w-100 h-100" style="object-fit: cover; transition: all 0.5s ease;" />
                    }
                </div>

                @if (Model.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any())
                {
                    <div class="card-body pt-3 pb-2">
                        <div class="d-flex flex-wrap gap-2 justify-content-center">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="thumbnail-wrapper active" data-image="@Url.Content(Model.ImageUrl)">
                                    <img src="@Url.Content(Model.ImageUrl)" alt="Main Image" class="thumbnail rounded" 
                                         style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;" />
                                </div>
                            }
                            @foreach (var hinhAnh in Model.HinhAnhSanPhams)
                            {
                                <div class="thumbnail-wrapper" data-image="@Url.Content(hinhAnh.LoaiHinhAnh)">
                                    <img src="@Url.Content(hinhAnh.LoaiHinhAnh)" alt="Product Image" class="thumbnail rounded" 
                                         style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;" />
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Product details column -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h1 class="fs-2 fw-bold mb-3">@Model.TenSanPham</h1>
                    
                    <div class="price-tag mb-3">
                        <span class="fs-3 fw-bold text-accent">@Model.GiaTheoKG.ToString("C0")</span>
                        <span class="text-muted ms-2">per kg</span>
                    </div>

                    <div class="mb-3">
                        <div class="star-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= ViewBag.AverageRating)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else if (i - 0.5 <= ViewBag.AverageRating)
                                {
                                    <i class="bi bi-star-half"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }
                            <span class="ms-2 text-muted">(@ViewBag.TotalReviews đánh giá)</span>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <span class="badge bg-success me-2">@Model.TinhTrang</span>
                        <span class="badge bg-secondary me-2">@Model.LoaiBaoQuan</span>
                    </div>
                    
                    <hr>
                    
                    <div class="product-details mb-4">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <span class="text-muted"><i class="bi bi-calendar2 me-2"></i>Harvest Date:</span>
                                    <p class="mb-0 fw-medium">@Model.NgayThuHoach.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <span class="text-muted"><i class="bi bi-geo-alt me-2"></i>Origin:</span>
                                    <p class="mb-0 fw-medium">@Model.NguonGoc</p>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <span class="text-muted"><i class="bi bi-box me-2"></i>Stock:</span>
                                    <p class="mb-0 fw-medium">@Model.SoLuong units</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <span class="text-muted"><i class="bi bi-snow me-2"></i>Storage:</span>
                                    <p class="mb-0 fw-medium">@Model.LoaiBaoQuan</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <h5 class="mb-2">Description</h5>
                        <p class="text-muted">@(string.IsNullOrEmpty(Model.MoTa) ? "No description available." : Model.MoTa)</p>
                    </div>
                    
                    <div class="action-buttons mt-4">
                        <form asp-controller="ShoppingCart" asp-action="AddToCart" method="post" class="d-inline">
                            <input type="hidden" name="maSanPham" value="@Model.MaSanPham" />
                            <input type="hidden" name="tenSanPham" value="@Model.TenSanPham" />
                            <input type="hidden" name="giaTheoKG" value="@Model.GiaTheoKG" />
                            <input type="hidden" name="imageUrl" value="@Model.ImageUrl" />
                            
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text">Qty</span>
                                        <input type="number" name="soLuong" class="form-control" value="1" min="1" max="@Model.SoLuong" />
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="bi bi-cart-plus me-2"></i>Add to Cart
                                    </button>
                                </div>
                            </div>
                        </form>
                        
                        <div class="d-flex mt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary me-2 w-50">
                                <i class="bi bi-arrow-left me-2"></i>Back to Products
                            </a>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="ManageHinhAnh" asp-route-maSanPham="@Model.MaSanPham" class="btn btn-outline-primary w-50">
                                    <i class="bi bi-images me-2"></i>Manage Images
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="row mt-5">
        <div class="col-12">
            <h3 class="mb-4">Đánh giá sản phẩm</h3>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Viết đánh giá của bạn</h5>
                        <form asp-action="AddReview" asp-controller="SanPham" method="post">
                            <input type="hidden" name="maSanPham" value="@Model.MaSanPham" />
                            
                            <div class="mb-3">
                                <label class="form-label">Xếp hạng sản phẩm</label>
                                <div class="rating-group">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" class="rating-input" name="xepHang" id="rating@(i)" value="@i" required />
                                        <label class="rating-label" for="rating@(i)" title="@i sao">★</label>
                                    }
                                </div>
                                <div id="ratingDescription" class="rating-description">
                                    Chọn số sao để đánh giá
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Bình luận</label>
                                <textarea name="binhLuan" class="form-control" rows="3" required></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Vui lòng <a href="@Url.Action("Login", "Account")">đăng nhập</a> để viết đánh giá
                </div>
            }

            @if (Model.DanhGias != null && Model.DanhGias.Any())
            {
                foreach (var danhGia in Model.DanhGias.OrderByDescending(d => d.NgayDanhGia))
                {
                    <div class="review-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-1">@danhGia.NguoiDung?.TenNguoiDung</h6>
                                <div class="star-rating mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= danhGia.XepHang)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                </div>
                            </div>
                            <span class="review-date">@danhGia.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <p class="mb-0">@danhGia.BinhLuan</p>
                    </div>
                }
            }
            else
            {
                <div class="text-muted">Chưa có đánh giá nào cho sản phẩm này</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý chuyển đổi hình ảnh khi click vào thumbnail
        document.querySelectorAll('.thumbnail-wrapper').forEach(wrapper => {
            wrapper.addEventListener('click', function() {
                const imageUrl = this.getAttribute('data-image');
                document.querySelector('.main-image').src = imageUrl;
                
                // Remove active class from all thumbnails
                document.querySelectorAll('.thumbnail-wrapper').forEach(w => w.classList.remove('active'));
                // Add active class to clicked thumbnail
                this.classList.add('active');
            });
        });

        // Xử lý hiển thị mô tả đánh giá sao
        const ratingInputs = document.querySelectorAll('.rating-input');
        const ratingDescription = document.getElementById('ratingDescription');
        const ratingTexts = {
            5: "Tuyệt vời - Sản phẩm vượt quá mong đợi",
            4: "Tốt - Hài lòng với sản phẩm",
            3: "Bình thường - Sản phẩm tạm được",
            2: "Không tốt - Cần cải thiện",
            1: "Rất tệ - Không hài lòng"
        };

        ratingInputs.forEach(input => {
            input.addEventListener('change', function() {
                const value = this.value;
                ratingDescription.textContent = ratingTexts[value];
            });
        });

        // Hiển thị mô tả khi hover
        const ratingLabels = document.querySelectorAll('.rating-label');
        ratingLabels.forEach(label => {
            label.addEventListener('mouseover', function() {
                const value = this.getAttribute('for').replace('rating', '');
                ratingDescription.textContent = ratingTexts[value];
            });
        });

        // Khôi phục mô tả của sao đã chọn khi không hover
        const ratingGroup = document.querySelector('.rating-group');
        ratingGroup.addEventListener('mouseleave', function() {
            const checkedInput = document.querySelector('.rating-input:checked');
            if (checkedInput) {
                ratingDescription.textContent = ratingTexts[checkedInput.value];
            } else {
                ratingDescription.textContent = "Chọn số sao để đánh giá";
            }
        });
    </script>
}