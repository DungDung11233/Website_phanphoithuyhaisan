@model IEnumerable<DoAnCoSo.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="row justify-content-between align-items-center mb-4">
    <!-- Search form -->
    <div class="col-md-8 mb-3 mb-md-0">
        <form asp-action="Index" method="get" class="d-flex">
            <input class="form-control search-box me-2" type="search" name="searchTerm" placeholder="Search for products..."
                   value="@ViewBag.SearchTerm" aria-label="Search">
            <button class="btn search-btn" type="submit">
                <i class="bi bi-search"></i> Search
            </button>
        </form>
    </div>
    
    <!-- Category dropdown -->
    <div class="col-md-4 text-md-end category-dropdown">
        <button class="btn dropdown-toggle" type="button" id="categoryDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-grid me-2"></i> Categories
        </button>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="categoryDropdown">
            @if (ViewBag.DanhMucs != null && ViewBag.DanhMucs.Count > 0)
            {
                foreach (var category in ViewBag.DanhMucs)
                {
                    <li><a class="dropdown-item" href="/SanPham/SanPhamTheoDanhMuc/@category.MaDanhMuc">@category.TenDanhMuc</a></li>
                }
            }
            else
            {
                <li><span class="dropdown-item text-muted">No categories available.</span></li>
            }
        </ul>
    </div>
</div>

<!-- Modern Carousel -->
<div id="mainCarousel" class="carousel slide modern-carousel" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="https://theme.hstatic.net/1000182631/1000966139/14/a_top_1.jpg?v=1669" class="d-block w-100" alt="Promotion 1">
            <div class="carousel-caption d-none d-md-block">
                <h3 class="fw-bold">Fresh Seafood Collection</h3>
                <p>Explore our premium selection of fresh seafood products</p>
                <a href="/SanPham" class="btn btn-light">Shop Now</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://theme.hstatic.net/1000182631/1000966139/14/a_top_2.jpg?v=1669" class="d-block w-100" alt="Promotion 2">
            <div class="carousel-caption d-none d-md-block">
                <h3 class="fw-bold">Special Offers</h3>
                <p>Great discounts on selected seafood items</p>
                <a href="/SanPham" class="btn btn-light">View Offers</a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<!-- Category highlights -->
<div class="row mt-5 mb-4">
    <div class="col-12">
        <h2 class="section-title">Shop By Category</h2>
    </div>
</div>

<div class="row g-4 mb-5">
    @if (ViewBag.DanhMucs != null && ViewBag.DanhMucs.Count > 0)
    {
        int count = 0;
        foreach (var category in ViewBag.DanhMucs)
        {
            if (count >= 3) break; // Display max 3 categories
            <div class="col-md-4">
                <div class="card category-card h-100">
                    <div class="category-card-overlay"></div>
                    <div class="card-body text-center">
                        <i class="bi bi-droplet-fill category-icon mb-3"></i>
                        <h3 class="card-title">@category.TenDanhMuc</h3>
                        <a href="/SanPham/SanPhamTheoDanhMuc/@category.MaDanhMuc" class="btn btn-outline-primary mt-3">Browse Products</a>
                    </div>
                </div>
            </div>
            count++;
        }
    }
</div>

<!-- Featured Products Section -->
<div class="row mt-5">
    <div class="col-12">
        <h2 class="section-title">Featured Products</h2>
    </div>
</div>

@if (Model.Any())
{
    <div class="row g-4 mb-5">
        @{
            int productCount = 0;
            foreach (var item in Model)
            {
                if (productCount >= 6) break; // Display max 6 products
                <div class="col-12 col-sm-6 col-lg-4 mb-4">
                    <div class="modern-card">
                        <div class="card-img-container">
                            <a asp-controller="SanPham" asp-action="Display" asp-route-id="@item.MaSanPham">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-product.jpg" : item.ImageUrl)"
                                    class="card-img-top"
                                    alt="@item.TenSanPham" />
                            </a>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.TenSanPham</h5>
                            <p class="price mb-3">@item.GiaTheoKG.ToString("C")</p>
                            <div class="product-details mb-3">
                                <span class="badge bg-light text-dark me-2 mb-2">
                                    <i class="bi bi-calendar me-1"></i> @item.NgayThuHoach.ToString("dd/MM/yyyy")
                                </span>
                                <span class="badge bg-light text-dark me-2 mb-2">
                                    <i class="bi bi-snow me-1"></i> @item.LoaiBaoQuan
                                </span>
                                <span class="badge bg-light text-dark mb-2">
                                    <i class="bi bi-check-circle me-1"></i> @item.TinhTrang
                                </span>
                            </div>
                            <div class="mt-auto">
                                <a asp-controller="SanPham" asp-action="Display" asp-route-id="@item.MaSanPham" 
                                   class="btn btn-outline-primary w-100 mb-2">View Details</a>
                                <a asp-controller="ShoppingCart" asp-action="AddToCart" 
                                   asp-route-maSanPham="@item.MaSanPham" 
                                   asp-route-tenSanPham="@item.TenSanPham" 
                                   asp-route-giaTheoKG="@item.GiaTheoKG" 
                                   asp-route-imageUrl="@item.ImageUrl" 
                                   class="btn btn-dark w-100">
                                    <i class="bi-cart-fill me-1"></i> Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                productCount++;
            }
        }
    </div>
    
    <div class="text-center mb-5">
        <a asp-controller="SanPham" asp-action="Index" class="btn btn-primary px-4">
            View All Products <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-exclamation-circle fs-3 d-block mb-3"></i>
        <h4>No products found</h4>
        <p class="mb-0">We couldn't find any products matching your criteria.</p>
    </div>
}

<!-- Benefits Section -->
<div class="row py-5 my-5 bg-light rounded-4">
    <div class="col-12 mb-4">
        <h2 class="section-title">Why Choose Us</h2>
    </div>
    <div class="col-md-4 text-center mb-4 mb-md-0">
        <div class="px-4">
            <i class="bi bi-truck fs-1 text-primary mb-3"></i>
            <h4>Fast Delivery</h4>
            <p class="text-muted">We deliver fresh seafood right to your doorstep within hours of harvesting.</p>
        </div>
    </div>
    <div class="col-md-4 text-center mb-4 mb-md-0">
        <div class="px-4">
            <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
            <h4>Quality Guaranteed</h4>
            <p class="text-muted">All our products are carefully inspected to ensure premium quality and freshness.</p>
        </div>
    </div>
    <div class="col-md-4 text-center">
        <div class="px-4">
            <i class="bi bi-arrow-repeat fs-1 text-primary mb-3"></i>
            <h4>Easy Returns</h4>
            <p class="text-muted">Not satisfied? We offer hassle-free returns and refunds on all our products.</p>
        </div>
    </div>
</div>

<style>
    /* Category cards */
    .category-card {
        border-radius: 16px;
        background: linear-gradient(to right, var(--primary), var(--secondary));
        color: white;
        border: none;
        overflow: hidden;
        position: relative;
        transition: all 0.3s ease;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .category-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
    }
    
    .category-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }
    
    .category-card .card-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
    }
    
    .category-card .btn-outline-primary {
        color: white;
        border-color: white;
    }
    
    .category-card .btn-outline-primary:hover {
        background-color: white;
        color: var(--primary);
    }
    
    /* Product badges */
    .product-details .badge {
        border-radius: 30px;
        padding: 0.5rem 0.75rem;
        font-weight: 500;
    }
</style>

@section Scripts {
    <script>
        // Ensure proper initialization of Bootstrap components
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize all tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}